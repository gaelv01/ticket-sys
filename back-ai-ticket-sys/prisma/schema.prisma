// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENTE
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketType {
  CORRECTIVE
  PREVENTIVE
}

enum Impact {
  HIGH
  MEDIUM
  LOW
}

enum Category {
  PRODUCTION
  TECHNICAL
  ADMINISTRATIVE
  INFRASTRUCTURE
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

enum TicketEventType {
  TICKET_CREATED
  AI_CLASSIFIED
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  EDITED
}

enum CommentAuthorType {
  USER
  AI
  SYSTEM
}

model User {
  uuid      String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdTickets  Ticket[] @relation("CreatedTickets")
  assignedTickets Ticket[] @relation("AssignedTickets")

  ticketEvents   TicketEvent[]
  ticketComments TicketComment[]

  @@map("users")
}

model Ticket {
  uuid        String       @id @default(uuid())
  title       String
  description String
  severity    Severity
  type        TicketType
  impact      Impact
  category    Category
  status      TicketStatus @default(OPEN)

  createdById  String
  createdBy    User    @relation("CreatedTickets", fields: [createdById], references: [uuid])
  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [uuid])

  // Trazabilidad de la sugerencia de IA
  aiSuggested  Boolean @default(false)
  aiConfidence Float?
  aiPayload    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events   TicketEvent[]
  comments TicketComment[]

  @@map("tickets")
  @@index([status])
  @@index([createdById])
  @@index([assignedToId])
}

model TicketEvent {
  uuid      String          @id @default(uuid())
  ticketId  String
  ticket    Ticket          @relation(fields: [ticketId], references: [uuid], onDelete: Cascade)
  actorId   String?
  actor     User?           @relation(fields: [actorId], references: [uuid])
  eventType TicketEventType
  payload   Json?
  createdAt DateTime        @default(now())

  @@index([ticketId])
  @@map("ticket_events")
}

model TicketComment {
  uuid       String            @id @default(uuid())
  ticketId   String
  ticket     Ticket            @relation(fields: [ticketId], references: [uuid], onDelete: Cascade)
  authorId   String?
  author     User?             @relation(fields: [authorId], references: [uuid])
  authorType CommentAuthorType
  content    String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([ticketId])
  @@map("ticket_comments")
}