{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "reporters": [
    "default",
    [
      "jest-html-reporter",
      {
        "pageTitle": "Ticket System E2E Test Report",
        "outputPath": "test-results-v3.html",
        "includeFailureMsg": true,
        "includeConsoleLog": true,
        "theme": "darkTheme"
      }
    ]
  ]
}